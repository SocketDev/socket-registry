            "allowDestructuring": true
          }
        ],
        "@typescript-eslint/return-await": ["error", "always"]
      },
      "plugins": ["typescript"]
    },
    {
      "files": ["**/*.d.{cts,mts,ts}"],
      "plugins": ["typescript"]
    },
    {
      "files": ["**/*.{cts,mts,ts}"],
      "rules": {
        "no-redeclare": "off",
        "no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_|^this$",
