{
  "name": "@socketregistry/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Socket.dev optimized package overrides",
  "homepage": "http://github.com/SocketDev/socket-registry",
  "license": "MIT",
  "author": {
    "name": "Socket Inc",
    "email": "eng@socket.dev",
    "url": "https://socket.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SocketDev/socket-registry.git"
  },
  "scripts": {
    "analyze-ci-failures": "node scripts/testing/analyze-ci-failures.mts",
    "build": "node scripts/repo/build.mts",
    "check": "node scripts/fleet/check.mts",
    "check-trusted": "node scripts/npm/check-trusted-packages.mts",
    "check:paths": "node scripts/fleet/check/paths-are-canonical.mts",
    "clean": "node -e \"require('node:fs').rmSync('node_modules/.cache', { recursive: true, force: true })\"",
    "cover": "node scripts/fleet/cover.mts",
    "fix": "node scripts/fleet/fix.mts",
    "format": "node scripts/fleet/format.mts",
    "format:check": "node scripts/fleet/format.mts --check",
    "generate-actions-allow-list": "node scripts/ci/generate-actions-allow-list.mts",
    "generate-actions-tree": "node scripts/ci/show-actions-tree.mts",
    "inline-action-shas": "node scripts/ci/inline-action-versions-as-shas.mts",
    "lint": "node scripts/fleet/lint.mts",
    "lockstep": "node scripts/fleet/lockstep.mts",
    "lockstep:emit-schema": "node scripts/fleet/lockstep-emit-schema.mts",
    "make-npm-override": "node scripts/npm/make-npm-override.mts",
    "npm:publish": "node scripts/fleet/publish-pipeline.mts",
    "package-npm-access": "node scripts/npm/set-npm-package-access.mts",
    "package-npm-publish": "node scripts/npm/publish-npm-packages.mts",
    "perf": "node scripts/repo/perf.mts",
    "security": "node scripts/fleet/security.mts",
    "setup": "node scripts/repo/setup.mts",
    "prepare": "node scripts/fleet/install-git-hooks.mts && node scripts/fleet/prepare.mts",
    "prepublishOnly": "echo 'ERROR: Use GitHub Actions workflow for publishing' && exit 1",
    "release-npm": "node scripts/npm/release-npm-packages.mts",
    "test": "node scripts/fleet/test.mts",
    "test:fuzz": "node scripts/repo/fuzz.mts",
    "test:npm": "node scripts/npm/run-vitest-npm.mts",
    "type": "tsgo --noEmit -p tsconfig.check.json",
    "update": "node scripts/fleet/update.mts",
    "update:external-tools": "node scripts/repo/update-external-tools.mts",
    "validate-ci": "node scripts/testing/reproduce-ci-locally.mts",
    "validate-packages": "node scripts/testing/validate-package-tests.mts",
    "setup-security-tools": "node .claude/hooks/fleet/setup-security-tools/install.mts",
    "ci:local": "node scripts/fleet/agent-ci-skip-locks.mts run --all --quiet --pause-on-failure --github-token",
    "weekly-update": "node scripts/fleet/weekly-update.mts",
    "weekly-update:ci": "node scripts/fleet/weekly-update-workflow.mts run",
    "doctor:auth": "node scripts/fleet/check/setup-is-prompt-less.mts",
    "sync-oxlint-rules": "node scripts/fleet/sync-oxlint-rules.mts",
    "sync-package-manager-pins": "node scripts/fleet/sync-package-manager-pins.mts",
    "sync-fleet": "node bootstrap/fleet.mjs",
    "doctor": "node scripts/fleet/doctor.mts",
    "gen:llms-txt": "node scripts/fleet/make-llms-txt.mts --no-ai",
    "setup:brew": "node scripts/fleet/setup/setup-brew.mts",
    "setup:go": "node scripts/fleet/setup/setup-go.mts",
    "setup:python": "node scripts/fleet/setup/setup-python.mts",
    "setup:refero": "node scripts/fleet/setup/setup-refero.mts",
    "setup:rust": "node scripts/fleet/setup/setup-rust.mts",
    "setup:mcp": "node scripts/fleet/setup/setup-mcp.mts"
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@babel/generator": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@inquirer/checkbox": "catalog:",
    "@inquirer/core": "catalog:",
    "@inquirer/prompts": "catalog:",
    "@mdn/browser-compat-data": "catalog:",
    "@npmcli/package-json": "catalog:",
    "@npmcli/promise-spawn": "catalog:",
    "@redwoodjs/agent-ci": "catalog:",
    "@sinclair/typebox": "catalog:",
    "@socketregistry/is-unicode-supported": "workspace:*",
    "@socketregistry/packageurl-js": "catalog:",
    "@socketregistry/packageurl-js-stable": "catalog:",
    "@socketsecurity/lib": "catalog:",
    "@socketsecurity/lib-stable": "catalog:",
    "@socketsecurity/sdk": "catalog:",
    "@socketsecurity/sdk-stable": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/mdast": "catalog:",
    "@types/node": "catalog:",
    "@types/normalize-package-data": "catalog:",
    "@types/npm-package-arg": "catalog:",
    "@types/npmcli__package-json": "catalog:",
    "@types/npmcli__promise-spawn": "catalog:",
    "@types/picomatch": "catalog:",
    "@types/semver": "catalog:",
    "@types/shell-quote": "catalog:",
    "@types/spdx-correct": "catalog:",
    "@types/spdx-expression-parse": "catalog:",
    "@types/validate-npm-package-name": "catalog:",
    "@types/which": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "@vitiate/core": "catalog:",
    "@zkochan/js-yaml": "catalog:",
    "browserslist": "catalog:",
    "c8": "catalog:",
    "cacache": "catalog:",
    "chrome-devtools-mcp": "catalog:",
    "clipboardy": "catalog:",
    "debug": "catalog:",
    "del": "catalog:",
    "del-cli": "catalog:",
    "didyoumean2": "catalog:",
    "eta": "catalog:",
    "fast-check": "catalog:",
    "fast-glob": "catalog:",
    "fast-sort": "catalog:",
    "fs-extra": "catalog:",
    "get-east-asian-width": "catalog:",
    "html5parser": "catalog:",
    "js-yaml": "catalog:",
    "libnpmpack": "catalog:",
    "magic-string": "catalog:",
    "make-fetch-happen": "catalog:",
    "markdownlint-cli2": "catalog:",
    "mdast-util-from-markdown": "catalog:",
    "micromark": "catalog:",
    "minimatch": "catalog:",
    "neosanitize": "catalog:",
    "nock": "catalog:",
    "normalize-package-data": "catalog:",
    "npm-package-arg": "catalog:",
    "npm-run-all2": "catalog:",
    "out-url": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "pacote": "catalog:",
    "playwright-core": "catalog:",
    "portless": "catalog:",
    "read-yaml-file": "catalog:",
    "regjsparser": "catalog:",
    "rolldown": "catalog:",
    "semver": "catalog:",
    "shell-quote": "catalog:",
    "source-map-support": "catalog:",
    "spdx-correct": "catalog:",
    "spdx-expression-parse": "catalog:",
    "streaming-iterables": "catalog:",
    "svgo": "catalog:",
    "tar": "catalog:",
    "taze": "catalog:",
    "trash": "catalog:",
    "type-coverage": "catalog:",
    "typescript": "catalog:",
    "update-browserslist-db": "catalog:",
    "validate-npm-package-name": "catalog:",
    "vitest": "catalog:",
    "vitiate": "catalog:",
    "which": "catalog:",
    "yargs-parser": "catalog:",
    "yoctocolors-cjs": "catalog:"
  },
  "typeCoverage": {
    "atLeast": 99,
    "cache": true,
    "ignore-non-null-assertion": true,
    "ignore-type-assertion": true,
    "ignoreAsAssertion": true,
    "ignoreCatch": true,
    "ignoreEmptyType": true,
    "ignoreFiles": [
      "test/**/*.{ts,mts}",
      "perf/**/*.{ts,mts}",
      "scripts/**/*.{ts,mts,d.mts}",
      "packages/**/*.{ts,d.ts}"
    ],
    "strict": true
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=24",
    "npm": ">=12.0.0",
    "pnpm": ">=11.0.5"
  },
  "allowScripts": {
    "cpu-features": false,
    "es5-ext": true,
    "protobufjs": false,
    "puppeteer": false,
    "rolldown": true,
    "ssh2": false
  },
  "npm-run-all2": {
    "nodeRun": true
  }
}
