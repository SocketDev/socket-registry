{
  "name": "@socketregistry/assert",
  "version": "1.0.23",
  "description": "Socket.dev optimized package override for assert",
  "keywords": [
    "Socket.dev",
    "package-overrides"
  ],
  "homepage": "https://github.com/SocketDev/socket-registry/tree/main/packages/npm/assert",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SocketDev/socket-registry.git",
    "directory": "packages/npm/assert"
  },
  "files": [
    "*.cjs",
    "*.d.ts",
    "**/*.js",
    "**/LICENSE",
    "**/LICENSE.original"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "node": {
        "types": "./assert.d.ts",
        "default": "./index.cjs"
      },
      "default": {
        "types": "./assert.d.ts",
        "default": "./package/build/assert.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=24"
  },
  "socket": {
    "categories": [
      "cleanup"
    ]
  }
}
