{
  "name": "@socketregistry/<%= it.name %>",
  "version": "<%= it.version %>",
  "description": "Socket.dev optimized package override for <%= it.originalName %>",
  "keywords": [
    "Socket.dev",
    "package-overrides"
  ],
  "homepage": "https://github.com/SocketDev/socket-registry/tree/main/packages/npm/<%= it.name %>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SocketDev/socket-registry.git",
    "directory": "packages/npm/<%= it.name %>"
  },
  "files": [
    "*.d.ts",
    "*.js"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./auto": {
      "types": "./auto.d.ts",
      "default": "./auto.js"
    },
    "./implementation": {
      "types": "./implementation.d.ts",
      "default": "./implementation.js"
    },
    "./polyfill": {
      "types": "./polyfill.d.ts",
      "default": "./polyfill.js"
    },
    "./shim": {
      "types": "./shim.d.ts",
      "default": "./shim.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "<%~ it.engines.node %>"
  },
  "socket": {
    "categories": "//_ <%~ JSON.stringify(it.categories) %>"
  }
}
