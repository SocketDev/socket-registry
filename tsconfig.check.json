{
  "extends": "./.config/fleet/tsconfig.check.base.json",
  "compilerOptions": {
    "declaration": true
  },
  "include": ["**/*.ts", "**/*.mts", "**/*.cts"],
  "exclude": [
    "**/.cache/**",
    "**/node_modules/**",
    "packages/npm/**",
    "scripts/**",
    "test/**/packages/**",
    "test/npm/**/*.d.ts",
    "test/npm/node_modules/**"
  ]
}
