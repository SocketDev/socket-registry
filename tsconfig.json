{
  "extends": "./.config/tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["**/*.ts", "**/*.mts", "**/*.cts"],
  "exclude": [
    "**/node_modules/**",
    "packages/npm/**",
    "scripts/**",
    "test/**/packages/**",
    "test/npm/node_modules/**",
    "test/npm/**/*.d.ts"
  ]
}
